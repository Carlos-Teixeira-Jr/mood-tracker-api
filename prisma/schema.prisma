generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())

  name         String
  email        String   @unique
  passwordHash String

  isActive     Boolean  @default(true)
  deletedAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  checkins     Checkin[]

  medications  Medication[]
  routines     RoutineItem[]
}

model Checkin {
  id String @id @default(uuid())

  userId String
  date   DateTime

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  mood           MoodEntry?
  sleep          SleepEntry?
  medicationLogs MedicationLog[]
  routineLogs    RoutineLog[]

  @@unique([userId, date], name: "userId_date")
  @@index([userId, date])
}

model Medication {
  id String @id @default(uuid())

  userId String

  name   String
  dosage String?

  active    Boolean @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  schedules MedicationSchedule[]
  logs      MedicationLog[]
}

model RoutineItem {
  id String @id @default(uuid())

  userId String

  title String

  active    Boolean @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  logs RoutineLog[]
}

model MoodEntry {
  id String @id @default(uuid())

  checkinId String @unique

  score        Int
  anxiety      Int?
  energy       Int?
  irritability Int?

  notes String?

  createdAt DateTime @default(now())

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
}

model SleepEntry {
  id String @id @default(uuid())

  checkinId String @unique

  hours Float
  quality Int?
  notes String?

  createdAt DateTime @default(now())

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
}

model MedicationSchedule {
  id String @id @default(uuid())

  medicationId String

  time String

  medication Medication @relation(fields: [medicationId], references: [id])
}

model MedicationLog {
  id String @id @default(uuid())

  checkinId String
  medicationId String

  takenAt DateTime @default(now())

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id])

  @@unique([checkinId, medicationId])
}

model RoutineLog {
  id String @id @default(uuid())

  checkinId String
  routineId String

  completedAt DateTime @default(now())

  checkin Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  routine RoutineItem @relation(fields: [routineId], references: [id])

  @@unique([checkinId, routineId])
}
